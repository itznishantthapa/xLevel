{
  "expo": {
    "name": "Level",
    "slug": "Level",
    "version": "1.3.0",
    "android": {
      "package": "com.blackonedevs.levelesportmatchmaking",
      "notification": {
        "icon": "./src/assets/ic_notification.png",
        "color": "#ffffff"
      }
    },
    "ios": {
      "bundleIdentifier": "com.blackonedevs.levelesportmatchmaking.v1"
    },
    "plugins": [
      "expo-audio",
      "expo-secure-store",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Level to save payment QR codes to your photo library.",
          "savePhotosPermission": "Allow Level to save payment QR codes to your photo library."
        }
      ]
    ]
  }
}
